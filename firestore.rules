rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.active == true;
    }

    // Share-code capability: a visitor who stores a valid claim code on their
    // own user doc may read the tab (transactions/payments/profile) of the
    // user that codes/{code} points at. The 8-char code is the secret; codes
    // cannot be listed, only fetched by exact id.
    function myClaimedCode() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('claimedCode', '');
    }

    function hasClaimOn(ownerId) {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && myClaimedCode() != ''
        && get(/databases/$(database)/documents/codes/$(myClaimedCode())).data.userId == ownerId;
    }

    match /settings/{settingId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /snacks/{snackId} {
      allow read: if signedIn() && (resource.data.active == true || isAdmin());
      allow create, update, delete: if isAdmin();
    }

    match /devices/{deviceId} {
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      // resource == null lets a first-time visitor check whether their
      // device doc exists yet (the browser get()s before creating it)
      allow read: if isAdmin()
        || (signedIn() && (resource == null || resource.data.uid == request.auth.uid));
      allow update: if isAdmin()
        || (signedIn()
            && resource.data.uid == request.auth.uid
            && request.resource.data.uid == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow create: if signedIn() && userId == request.auth.uid;
      allow read: if isAdmin()
        || (signedIn() && userId == request.auth.uid)
        || hasClaimOn(userId);
      allow update: if isAdmin() || (signedIn() && userId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /codes/{code} {
      // fetch by exact code only — no listing, so codes stay unguessable
      allow get: if signedIn();
      allow list, create, update, delete: if isAdmin();
    }

    match /transactions/{transactionId} {
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == "active";
      allow read: if isAdmin()
        || (signedIn() && resource.data.uid == request.auth.uid)
        || hasClaimOn(resource.data.userId);
      // owners/claim-holders may only set their agree/disagree verdict;
      // everything else on a transaction stays admin-only
      allow update: if isAdmin()
        || ((signedIn() && resource.data.uid == request.auth.uid || hasClaimOn(resource.data.userId))
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['userStatus', 'userStatusAt'])
            && (!('userStatus' in request.resource.data)
                || request.resource.data.userStatus in ['agreed', 'disputed']));
      allow delete: if isAdmin();
    }

    match /payments/{paymentId} {
      allow read: if isAdmin()
        || (signedIn() && resource.data.userId == request.auth.uid)
        || hasClaimOn(resource.data.userId);
      allow create, update, delete: if isAdmin();
    }

    match /adjustments/{adjustmentId} {
      allow read: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
      allow create, update, delete: if isAdmin();
    }

    match /admins/{uid} {
      allow read: if isAdmin() || (signedIn() && uid == request.auth.uid);
      allow create, update, delete: if isAdmin();
    }

    match /feedback/{feedbackId} {
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.message is string
        && request.resource.data.message.size() > 0
        && request.resource.data.message.size() <= 2000;
      allow read: if isAdmin() || (signedIn() && resource.data.uid == request.auth.uid);
      allow update, delete: if isAdmin();
    }
  }
}

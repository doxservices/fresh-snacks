rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.active == true;
    }

    // Share-code capability: a visitor who stores a valid claim code in the
    // authorization-only claims collection may read the tab that codes/{code}
    // points at. Claims never appear as customer profiles in admin accounting.
    // The code is the secret; codes cannot be listed, only fetched by exact id.
    function myClaimedCode() {
      return get(/databases/$(database)/documents/claims/$(request.auth.uid)).data.get('code', '');
    }

    function hasClaimOn(ownerId) {
      return signedIn()
        && exists(/databases/$(database)/documents/claims/$(request.auth.uid))
        && myClaimedCode() != ''
        && get(/databases/$(database)/documents/codes/$(myClaimedCode())).data.userId == ownerId;
    }

    // Device-linking: a "link"-type code (as opposed to the read-only "view"
    // codes above) lets a new browser join a customer's profile as a full
    // member (own anonymous uid, but shares the tab). hasLinkOn() only gates
    // the one-time join step (adding yourself to linkedUids, capped at 3);
    // isLinkedMember() gates everything ongoing (logging snacks, editing the
    // shared profile) and requires you to already be in that array, so a
    // reused link code can never let in more than 3 members.
    function claimedCodeType() {
      return get(/databases/$(database)/documents/codes/$(myClaimedCode())).data.get('type', 'view');
    }

    function hasLinkOn(ownerId) {
      return hasClaimOn(ownerId) && claimedCodeType() == 'link';
    }

    function isLinkedMember(ownerId) {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(ownerId))
        && request.auth.uid in get(/databases/$(database)/documents/users/$(ownerId)).data.get('linkedUids', []);
    }

    match /settings/{settingId} {
      allow read: if settingId == 'app' || isAdmin();
      allow write: if isAdmin();
    }

    match /snacks/{snackId} {
      allow read: if resource.data.active == true || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /claims/{uid} {
      allow create, update: if signedIn()
        && uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.code is string
        && request.resource.data.code.size() >= 4
        && request.resource.data.code.size() <= 16;
      allow read, delete: if isAdmin() || (signedIn() && uid == request.auth.uid);
    }

    match /devices/{deviceId} {
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      // resource == null lets a first-time visitor check whether their
      // device doc exists yet (the browser get()s before creating it)
      allow read: if isAdmin()
        || (signedIn() && (resource == null || resource.data.uid == request.auth.uid));
      allow update: if isAdmin()
        || (signedIn()
            && resource.data.uid == request.auth.uid
            && request.resource.data.uid == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      // isAdmin() lets the snack keeper pre-create a guest profile (a
      // synthetic id, not tied to any device's own auth uid) before
      // sharing an invite to it - the admin can build out the tab first.
      allow create: if isAdmin() || (signedIn() && userId == request.auth.uid);
      allow read: if isAdmin()
        || (signedIn() && userId == request.auth.uid)
        || hasClaimOn(userId)
        || isLinkedMember(userId);
      allow update: if isAdmin()
        || (signedIn() && userId == request.auth.uid)
        || (signedIn() && request.auth.uid in resource.data.get('linkedUids', []))
        || (hasLinkOn(userId)
            && resource.data.get('linkedUids', []).size() < 3
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['linkedUids']));
      allow delete: if isAdmin();
    }

    match /codes/{code} {
      // fetch by exact code only — no listing, so codes stay unguessable
      allow get: if signedIn();
      allow list, create, update, delete: if isAdmin();
    }

    match /transactions/{transactionId} {
      // isAdmin() lets the snack keeper log a snack directly onto any
      // customer's tab (e.g. building out a guest profile before sharing
      // it, or adding on a regular's behalf) - not just their own uid or
      // a tab they're a linked member of.
      allow create: if isAdmin()
        || (signedIn()
            && request.resource.data.userId == request.resource.data.uid
            && (request.resource.data.uid == request.auth.uid || isLinkedMember(request.resource.data.uid))
            && request.resource.data.status == "active");
      // uid == userId is guaranteed on every transaction doc (enforced by
      // the create rule above); this branch checks userId, not uid, so it
      // aligns with the field getOwnTransactions() actually queries on —
      // a list query is rejected outright if the rule can't be satisfied
      // using the same field the query filters by, even when zero
      // documents would actually match (e.g. a brand-new customer).
      allow read: if isAdmin()
        || (signedIn() && resource.data.userId == request.auth.uid)
        || hasClaimOn(resource.data.userId)
        || isLinkedMember(resource.data.userId);
      // Customers attached to a tab may set their verdict or correct the
      // transaction date; everything else stays admin-only.
      allow update: if isAdmin()
        || ((signedIn() && resource.data.uid == request.auth.uid
              || hasClaimOn(resource.data.userId)
              || isLinkedMember(resource.data.userId))
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['userStatus', 'userStatusAt', 'createdDate', 'dateEditedAt'])
            && (!('userStatus' in request.resource.data)
                || request.resource.data.userStatus in ['agreed', 'disputed'])
            && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['createdDate'])
                || (request.resource.data.createdDate is string
                    && request.resource.data.createdDate.matches('^\\d{4}-\\d{2}-\\d{2}$'))));
      allow delete: if isAdmin();
    }

    match /payments/{paymentId} {
      allow read: if isAdmin()
        || (signedIn() && resource.data.userId == request.auth.uid)
        || hasClaimOn(resource.data.userId)
        || isLinkedMember(resource.data.userId);
      allow create, update, delete: if isAdmin();
    }

    match /adjustments/{adjustmentId} {
      allow read: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
      allow create, update, delete: if isAdmin();
    }

    match /admins/{uid} {
      allow read: if isAdmin() || (signedIn() && uid == request.auth.uid);
      allow create, update, delete: if isAdmin();
    }

    match /feedback/{feedbackId} {
      // Feedback is a deliberate authenticated write, but never provisions a
      // customer profile or device record.
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.message is string
        && request.resource.data.message.size() > 0
        && request.resource.data.message.size() <= 2000
        && request.resource.data.status == 'new'
        && request.resource.data.createdAt == request.time;
      allow read: if isAdmin() || (signedIn() && resource.data.uid == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    // Physical stock ledger (admin restocking a bin). Entirely separate from
    // /transactions (a customer taking a snack) — no customer access at all.
    match /inventory/{entryId} {
      allow read, create, update, delete: if isAdmin();
    }
  }
}
